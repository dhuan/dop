# Remove from outside

# INPUT

{
  "foo": {
    "bar": [
      1,
      2,
      3
    ]
  }
}

# SCRIPT

if [ "${KEY}" = "foo.bar[1]" ]
then
    dop del foo.bar
fi

# EXPECT

{"foo":{}}

---

# Try to remove a value that does not exist

# INPUT

{"foo":{"bar":1}}

# SCRIPT

dop del this.value.does.not.exist

# EXPECT

{"foo":{"bar":1}}
