# Convert from JSON to YAML: With array

# OPTIONS

-o yaml

# INPUT

[1,2,3]

# EXPECT

- 1
- 2
- 3

---

# Convert from JSON to YAML: With objects and arrays

# OPTIONS

-o yaml

# INPUT

{"foo":["bar",{"hello":"world"}]}

# EXPECT

foo:
- bar
- hello: world

---

# Convert from YAML to JSON

# OPTIONS

-o json

# INPUT

- 1
- 2
- 3

# EXPECT

[1,2,3]

---

# Convert from JSON to TOML

# OPTIONS

-o toml

# INPUT

{
  "some_obj": {
    "foo": "bar"
  },
  "some_number": 123,
  "some_list": [
    1,
    2,
    3
  ],
  "some_bool": true
}

# EXPECT

some_bool = true
some_list = [1, 2, 3]
some_number = 123

[some_obj]
foo = "bar"
