# Remove one value from array

# INPUT

[1,2,3]

# SCRIPT

if [ "${KEY}" = "[2]" ]
then
    dop del
fi

# EXPECT

[1,2]

---

# Remove one value from object

# INPUT

{
  "foo": {
    "bar": 123,
    "stay": true
  }
}

# SCRIPT

if [ "${KEY}" = "foo.bar" ]
then
    dop del
fi

# EXPECT

{"foo":{"stay":true}}

---

# Remove a whole object

# INPUT

{
  "foo": {
    "bar": {
      "some_object": {
        "a": "b",
        "c": "d",
        "some_list": [
          1,
          2,
          3
        ]
      }
    },
    "stay": true
  }
}

# SCRIPT

if [ "${KEY}" = "foo.bar.some_object" ]
then
    dop del
fi

# EXPECT

{"foo":{"bar":{},"stay":true}}
