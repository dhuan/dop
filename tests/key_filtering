# Key filtering with "-k": Modify values

# OPTIONS

-k ^some_data.list_a.[0-9]{1,}$

# SCRIPT

echo $((${VALUE} * 2)) > $SET_VALUE

# INPUT

{
  "some_data": {
    "list_a": [ 1, 2, 3 ],
    "list_b": [ 1, 2, 3 ]
  }
}

# EXPECT

{"some_data":{"list_a":[2,4,6],"list_b":[1,2,3]}}

---

# Key filtering with "-k": Remove all items from array

# OPTIONS

-k data.some_list.\d+

# SCRIPT

exit 1

# INPUT

{
  "data": {
    "some_list": [ 1, 2, 3 ]
  }
}

# EXPECT

{"data":{"some_list":[]}}
