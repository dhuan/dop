# Key filtering with "-k": Modify values

# OPTIONS

-k some_data.list_a\[

# SCRIPT

dop set $((${VALUE} * 2))

# INPUT

{
  "some_data": {
    "list_a": [ 1, 2, 3 ],
    "list_b": [ 1, 2, 3 ]
  }
}

# EXPECT

{"some_data":{"list_a":[2,4,6],"list_b":[1,2,3]}}

---

# Key filtering with "-k": Remove all items from array

# OPTIONS

--key-filter data.some_list\[\d+\]

# SCRIPT

exit 1

# INPUT

{
  "data": {
    "some_list": [ 1, 2, 3 ]
  }
}

# EXPECT

{"data":{"some_list":[]}}

---

# Key filtering with "-K": Matching exact

# OPTIONS

-K data.some_list[1]

# SCRIPT

dop set $((${VALUE} * 2))

# INPUT

{
  "data": {
    "some_list": [ 1, 2, 3 ]
  }
}

# EXPECT

{"data":{"some_list":[1,4,3]}}
