# Remove one value from array

# INPUT

- 1
- 2
- 3

# SCRIPT

test "${KEY}" != "2"

# EXPECT

- 1
- 2

---

# Remove one value from object

# INPUT

foo:
  bar: 123
  stay: true

# SCRIPT

test "${KEY}" != "foo.bar"

# EXPECT

foo:
  stay: true

---

# Remove a whole object

# INPUT

foo:
  bar:
    some_object:
      a: b
      c: d
      some_list:
        - 1
        - 2
        - 3
  stay: true

# SCRIPT

test "${KEY}" != "foo.bar.some_object"

# EXPECT

foo:
  bar: {}
  stay: true
