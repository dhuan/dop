# Transform into an object

# INPUT

[1,2,3]

# SCRIPT

if [ "${KEY}" = "[1]" ]
then
    dop set '{"foo":"bar"}' 
fi

# EXPECT

[1,{"foo":"bar"},3]

---

# Transform into a string

# INPUT

[1,2,3]

# SCRIPT

if [ "${KEY}" = "[1]" ]
then
    dop set -s "${VALUE}"
fi

# EXPECT

