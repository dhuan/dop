# set: array

# INPUT

[1,2,3]

# SCRIPT

set(get() * 2)

# EXPECT

[2,4,6]

---

# set: object

# INPUT

{"data":{"foo":"bar"}}

# SCRIPT

if type(VALUE) == "string" then
    set("BAR")
end

# EXPECT

{"data":{"foo":"BAR"}}

---

# set: replace with an object

# OPTIONS

-K [1]

# INPUT

[1,2,3]

# SCRIPT

set({foo = "bar"})

# EXPECT

[1,{"foo":"bar"},3]

---

# set: replace with a list

# OPTIONS

-K [1]

# INPUT

[1,2,3]

# SCRIPT

set({50, 70})

# EXPECT

[1,[50,70],3]

---

# set: replace with a boolean

# OPTIONS

-K [1]

# INPUT

[1,2,3]

# SCRIPT

set(false)

# EXPECT

[1,false,3]
